PORT=4000
# Frontend origin (no trailing slash — must match browser origin for CORS)
CLIENT_URL=https://lockseed.vercel.app
NODE_ENV=production

MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/lockseed

JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

ERP_API_BASE_URL=https://backend.codewithseth.co.ke
ERP_ORG_ID=your-org-id
# ERP_API_TOKEN=   # required if production ERP returns 401

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Lockseed Supplies <info@yourdomain.com>"
