# ─── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Website backend API (Express server) ─────────────
# Production deployed backend:
NEXT_PUBLIC_API_URL=https://lockseed.codewithseth.co.ke
# Local development: NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── MongoDB (website database only — not ERP data) ───
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.p0v1wer.mongodb.net/lockseed

# ─── Auth (JWT + httpOnly cookies) ────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# ─── ERP (business source of truth) ───────────────────
# Local development (no auth):
ERP_API_BASE_URL=http://localhost:5010
# Production (may require token):
# ERP_API_BASE_URL=https://backend.codewithseth.co.ke
ERP_ORG_ID=your-org-id
# ERP_API_TOKEN=   # required for production ERP if it returns 401

# ─── Domain email (SMTP) ──────────────────────────────
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=info@yourdomain.com
SMTP_PASS=your-smtp-password
EMAIL_FROM="Lockseed Supplies <info@yourdomain.com>"
